# --- Service ---
NODE_ENV=development
SERVICE_NAME=project-service
PROJECT_PORT=3001

# --- Database ---
MONGODB_URI=mongodb+srv://username:password@your-cosmos.mongo.cosmos.azure.com/kubeguard?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000

# --- Security ---
INTERNAL_SECRET=replace-with-64-char-random-string
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=exactly-32-characters-here-1234!

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_personal_access_token
GATEWAY_PUBLIC_URL=https://your-gateway-domain.com
